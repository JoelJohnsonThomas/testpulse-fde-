# Copy to .env (git-ignored) and fill in. Only needed for the full TestRelic cloud loop.
# TestPulse's plain-English summary and `npm run demo` work WITHOUT any of these.

# Required for uploading test results to the TestRelic cloud dashboard (Part 3).
# Create at: https://platform.testrelic.ai  ->  Settings -> API Keys
TESTRELIC_API_KEY=

# Optional: push the plain-English summary to Slack (the "last mile" — where devs actually look).
# Create an Incoming Webhook in your Slack workspace and paste the URL here.
SLACK_WEBHOOK_URL=
